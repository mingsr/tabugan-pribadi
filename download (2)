        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { position: 'bottom', labels: { color: colorText, usePointStyle: true, boxWidth: 8, padding: 16, font: { size: 11.5 } } },
            tooltip: { callbacks: { label: (ctx) => ctx.dataset.label + ': ' + formatRupiah(ctx.parsed.y) } },
          },
          scales: commonScales,
        },
      });

      // ---- Chart 2: Perkembangan Saldo (line, kumulatif) ----
      if (state.charts.balance) state.charts.balance.destroy();
      state.charts.balance = new Chart($('#chartBalance').getContext('2d'), {
        type: 'line',
        data: {
          labels: labels,
          datasets: [{
            label: 'Saldo',
            data: agg.balance,
            borderColor: colorViolet,
            backgroundColor: hexToRgba(colorViolet, 0.14),
            fill: true,
            tension: 0.35,
            pointRadius: 3,
            pointBackgroundColor: colorViolet,
            borderWidth: 2.5,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (ctx) => 'Saldo: ' + formatRupiah(ctx.parsed.y) } },
          },
          scales: commonScales,
        },
      });

      // ---- Chart 3: Ringkasan Bulanan (selalu per bulan, 6 bulan terakhir,
      //      independen dari filter periode di atas) ----
      const monthlyBuckets = buildBuckets('month');
      const monthlyAgg = aggregateByBuckets(monthlyBuckets, state.transactions);
      const monthlyLabels = monthlyBuckets.map(b => b.label);

      if (state.charts.monthly) state.charts.monthly.destroy();
      state.charts.monthly = new Chart($('#chartMonthly').getContext('2d'), {
        type: 'bar',
        data: {
          labels: monthlyLabels,
          datasets: [
            { label: 'Pemasukan', data: monthlyAgg.income, backgroundColor: colorMint, borderRadius: 4, maxBarThickness: 26 },
            { label: 'Pengeluaran', data: monthlyAgg.expense, backgroundColor: colorCoral, borderRadius: 4, maxBarThickness: 26 },
            { label: 'Tabungan', data: monthlyAgg.saving, backgroundColor: colorGold, borderRadius: 4, maxBarThickness: 26 },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { position: 'bottom', labels: { color: colorText, usePointStyle: true, boxWidth: 8, padding: 16, font: { size: 11.5 } } },
            tooltip: { callbacks: { label: (ctx) => ctx.dataset.label + ': ' + formatRupiah(ctx.parsed.y) } },
          },
          scales: commonScales,
        },
      });
    },

    renderInsight() {
      const insight = computeInsights(state.transactions);
      const list = $('#insightList');
      list.innerHTML = '';

      const items = [];

      if (insight.topIncomeMonth) {
        items.push({
          icon: 'fa-solid fa-arrow-trend-up',
          html: 'Bulan dengan pemasukan terbesar: <strong>' + insight.topIncomeMonth.label + '</strong> (' + formatRupiah(insight.topIncomeMonth.income) + ')',
        });
      }
      if (insight.topExpenseMonth) {
        items.push({
          icon: 'fa-solid fa-arrow-trend-down',
          html: 'Bulan dengan pengeluaran terbesar: <strong>' + insight.topExpenseMonth.label + '</strong> (' + formatRupiah(insight.topExpenseMonth.expense) + ')',
        });
      }
      items.push({
        icon: 'fa-solid fa-percent',
        html: 'Persentase tabungan terhadap pemasukan (sepanjang waktu): <strong>' + insight.savingPercent + '%</strong>',
      });

      if (items.length === 0) {
        list.innerHTML = '<li class="insight-item"><span class="insight-text">Belum cukup data untuk menampilkan insight.</span></li>';
        return;
      }

      items.forEach(item => {
        const li = document.createElement('li');
        li.className = 'insight-item';
        li.innerHTML = '<span class="insight-icon"><i class="' + item.icon + '"></i></span><span class="insight-text">' + item.html + '</span>';
        list.appendChild(li);
      });
    },
  };

  function formatRupiahShort(n) {
    const abs = Math.abs(n);
    if (abs >= 1000000) return (n / 1000000).toFixed(abs % 1000000 === 0 ? 0 : 1) + 'jt';
    if (abs >= 1000) return (n / 1000).toFixed(0) + 'rb';
    return String(n);
  }

  function hexToRgba(hex, alpha) {
    let c = hex.replace('#', '');
    if (c.length === 3) c = c.split('').map(ch => ch + ch).join('');
    const num = parseInt(c, 16);
    const r = (num >> 16) & 255, g = (num >> 8) & 255, b = num & 255;
    return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
  }

  /* ---------------------------------------------------------
     15. ACHIEVEMENT PAGE — grid, search, filter rarity/status,
     empty/loading state. Logika unlock ada di bagian 6 + achievements.js;
     modul ini murni tampilan.
  --------------------------------------------------------- */

  const AchievementPage = {
    async ensureLoaded() {
      if (state.achPageLoaded) {
        this.render();
        return;
      }
      await this.simulateFetch();
      await this.loadData();
      state.achPageLoaded = true;
      this.render();
    },

    async simulateFetch() {
      $('#achSkeleton').hidden = false;
      $('#achGrid').hidden = true;
      $('#achEmptyState').hidden = true;
      $('#achResultCount').hidden = true;
      await delay(450); // simulasi latency network (tetap dijaga walau nanti fetch asli, supaya transisi loading tidak "kedip")
      $('#achSkeleton').hidden = true;
      $('#achGrid').hidden = false;
    },

    /**
     * Kalau tersambung & terautentikasi ke backend, ambil daftar
     * achievement ASLI (47 item, ACHIEVEMENTS_MASTER) lewat
     * getAchievements. Kalau tidak (offline / belum tersambung),
     * state.remoteAchievements tetap null dan getFullList() akan
     * jatuh ke mesin lokal js/achievements.js (19 item).
     */
    async loadData() {
      const status = NUMD_SYNC.getStatus();
      if (status.online && status.authenticated) {
        try {
          const result = await NUMD_ACH_API.getAchievements();
          state.remoteAchievements = result;
          return;
        } catch (err) {
          Toast.show('Gagal memuat achievement dari cloud, memakai data lokal.', 'info');
        }
      }
      state.remoteAchievements = null;
    },

    init() {
      $('#achSearchInput').addEventListener('input', (e) => {
        state.achFilters.search = e.target.value;
        this.render();
      });

      $('#achStatusChips').addEventListener('click', (e) => {
        const chip = e.target.closest('.filter-chip');
        if (!chip) return;
        $$('#achStatusChips .filter-chip').forEach(c => c.classList.remove('is-active'));
        chip.classList.add('is-active');
        state.achFilters.status = chip.getAttribute('data-status');
        this.render();
      });

      $('#achRarityChips').addEventListener('click', (e) => {
        const chip = e.target.closest('.filter-chip');
        if (!chip) return;
        $$('#achRarityChips .filter-chip').forEach(c => c.classList.remove('is-active'));
        chip.classList.add('is-active');
        state.achFilters.rarity = chip.getAttribute('data-rarity');
        this.render();
      });

      $('#achEmptyResetBtn').addEventListener('click', () => {
        state.achFilters = { search: '', status: 'ALL', rarity: 'ALL' };
        $('#achSearchInput').value = '';
        $$('#achStatusChips .filter-chip').forEach(c => c.classList.toggle('is-active', c.getAttribute('data-status') === 'ALL'));
        $$('#achRarityChips .filter-chip').forEach(c => c.classList.toggle('is-active', c.getAttribute('data-rarity') === 'ALL'));
        this.render();
      });
    },

    getFullList() {
      if (state.remoteAchievements && Array.isArray(state.remoteAchievements.achievements)) {
        // Normalisasi field backend (achievement_key, dst) ke bentuk yang
        // dipakai buildCard()/getFiltered() supaya keduanya tidak perlu
        // tahu data ini datang dari lokal atau cloud.
        return state.remoteAchievements.achievements.map(a => ({
          key: a.achievement_key,
          nama: a.nama,
          deskripsi: a.deskripsi,
          clue: a.clue,
          icon: a.icon,
          category: a.category,
          rarity: a.rarity,
          is_secret: a.is_secret,
          xp_reward: a.xp_reward,
          is_unlocked: a.is_unlocked,
          tanggal_unlock: a.tanggal_unlock,
          progress: a.progress,
          target: a.target,
          progress_percent: a.progress_percent,
        }));
      }
      return NUMD_ACH.getAll(state.unlockedAchievements, getAchievementStats());
    },

    getFiltered(fullList) {
      const f = state.achFilters;
      const q = f.search.trim().toLowerCase();

      return fullList.filter(ach => {
        if (f.status === 'UNLOCKED' && !ach.is_unlocked) return false;
        if (f.status === 'LOCKED' && ach.is_unlocked) return false;
        if (f.rarity !== 'ALL' && ach.rarity !== f.rarity) return false;

        if (q) {
          // Untuk achievement rahasia yang masih terkunci, pencarian
          // hanya mencocokkan teks yang benar-benar tampil ("???" /
          // clue) — bukan nama/deskripsi asli — supaya tidak membocorkan.
          const searchable = (ach.is_secret && !ach.is_unlocked)
            ? ((ach.clue || '') + ' misteri rahasia')
            : (ach.nama + ' ' + ach.deskripsi);
          if (!searchable.toLowerCase().includes(q)) return false;
        }
        return true;
      });
    },

    render(newlyUnlockedKeys) {
      if (!state.achPageLoaded) return;

      const sourceNote = $('#achSourceNote');
      if (state.remoteAchievements) {
        sourceNote.hidden = false;
        sourceNote.innerHTML = '<i class="fa-solid fa-cloud"></i> Data achievement dari Google Sheets (' + state.remoteAchievements.total + ' total)';
      } else {
        sourceNote.hidden = false;
        sourceNote.innerHTML = '<i class="fa-solid fa-hard-drive"></i> Mode offline — achievement dihitung lokal di perangkatmu';
      }

      const fullList = this.getFullList();

      // Ringkasan (selalu dari full list, tidak ikut ter-filter)
      const unlockedCount = fullList.filter(a => a.is_unlocked).length;
      const totalCount = fullList.length;
      const overallPct = totalCount > 0 ? Math.round((unlockedCount / totalCount) * 100) : 0;

      $('#achTotalCount').textContent = totalCount;
      $('#achUnlockedCount').textContent = unlockedCount;
      $('#achLockedCount').textContent = totalCount - unlockedCount;
      $('#achOverallProgress').textContent = overallPct + '%';

      const rows = this.getFiltered(fullList);
      const grid = $('#achGrid');
      const empty = $('#achEmptyState');
      const count = $('#achResultCount');

      grid.innerHTML = '';

      if (rows.length === 0) {
        grid.hidden = true;
        count.hidden = true;
        empty.hidden = false;
        const hasActiveFilter = state.achFilters.search.trim() !== '' || state.achFilters.status !== 'ALL' || state.achFilters.rarity !== 'ALL';
        $('#achEmptyMessage').textContent = hasActiveFilter
          ? 'Coba ubah kata kunci pencarian atau filter yang kamu gunakan.'
          : 'Belum ada achievement pada kategori ini.';
        $('#achEmptyResetBtn').hidden = !hasActiveFilter;
        return;
      }

      grid.hidden = false;
      empty.hidden = true;
      count.hidden = false;
      count.textContent = rows.length + ' dari ' + totalCount + ' achievement';

      rows.forEach(ach => {
        grid.appendChild(this.buildCard(ach, newlyUnlockedKeys && newlyUnlockedKeys.includes(ach.key)));
      });
    },

    buildCard(ach, justUnlocked) {
      const isHiddenSecret = ach.is_secret && !ach.is_unlocked;
      const displayName = isHiddenSecret ? '???' : ach.nama;
      const displayDesc = isHiddenSecret ? (ach.clue || 'Rahasia — terbuka setelah syarat tertentu terpenuhi.') : ach.deskripsi;
      const displayIcon = (ach.is_unlocked || !isHiddenSecret) ? ach.icon : '🔒';

      const card = document.createElement('article');
      card.className = 'ach-card' + (ach.is_unlocked ? '' : ' is-locked') + (justUnlocked ? ' just-unlocked' : '');
      card.setAttribute('data-rarity', ach.rarity);

      let progressHtml = '';
      if (ach.progress !== null && ach.target !== null) {
        // Heuristik format: achievement kategori SAVING dengan progress
        // saving_total selalu bernilai besar (>= ratusan ribu) — beda
        // dari hitungan (jumlah transaksi/hari) yang kecil. Dipakai
        // (bukan trigger_type) supaya berlaku sama untuk data lokal
        // MAUPUN data dari backend (yang tidak mengirim trigger_type).
        const isCurrency = ach.category === 'SAVING' && ach.target >= 1000;
        const progLabel = isCurrency
          ? formatRupiah(ach.progress) + ' / ' + formatRupiah(ach.target)
          : ach.progress.toLocaleString('id-ID') + ' / ' + ach.target.toLocaleString('id-ID');
        progressHtml = ''
          + '<div class="ach-card-progress">'
          +   '<div class="ach-card-progress-bar"><div class="ach-card-progress-fill" style="width:' + ach.progress_percent + '%"></div></div>'
          +   '<div class="ach-card-progress-label"><span>' + progLabel + '</span><span>' + ach.progress_percent + '%</span></div>'
          + '</div>';
      } else if (isHiddenSecret) {
        progressHtml = '<p class="ach-card-secret-note"><i class="fa-solid fa-eye-slash"></i> Achievement rahasia — ' + escapeHtml(ach.clue || 'petunjuk belum tersedia') + '</p>';
      }

      const footerHtml = ach.is_unlocked
        ? '<div class="ach-card-footer"><i class="fa-solid fa-circle-check"></i> Terbuka ' + formatTanggalPendek(ach.tanggal_unlock) + ' · +' + ach.xp_reward + ' XP</div>'
        : '';

      card.innerHTML = ''
        + '<div class="ach-card-icon">' + displayIcon + '</div>'
        + '<div class="ach-card-body">'
        +   '<div class="ach-card-head">'
        +     '<div>'
        +       '<p class="ach-card-name">' + escapeHtml(displayName) + '</p>'
        +       '<p class="ach-card-desc">' + escapeHtml(displayDesc) + '</p>'
        +     '</div>'
        +     '<span class="ach-rarity-badge">' + NUMD_ACH.RARITY_LABEL[ach.rarity] + '</span>'
        +   '</div>'
        +   progressHtml
        +   footerHtml
        + '</div>';

      return card;
    },
  };

  /* ---------------------------------------------------------
     16. INTEGRASI BACKEND (Tahap 6) — ConnectionUI, sinkronisasi
     mutasi CRUD, dan sync-down awal. Status koneksi/antrean offline
     dikelola modul terpisah js/api/syncManager.js (NUMD_SYNC);
     bagian ini menjembatani ke UI (indikator, modal, toast).
  --------------------------------------------------------- */

  const ConnectionUI = {
    init() {
      NUMD_SYNC.onStatusChange((status) => this.updateUI(status));

      $('#connIndicator').addEventListener('click', () => this.openModal());
      $('#connModalClose').addEventListener('click', () => this.closeModal());
      $('#connModalCancel').addEventListener('click', () => this.closeModal());
      $('#connModalOverlay').addEventListener('click', (e) => {
        if (e.target === $('#connModalOverlay')) this.closeModal();
      });
      $('#connForm').addEventListener('submit', (e) => this.handleConnect(e));
      $('#connRetryBtn').addEventListener('click', () => this.handleRetry());
      $('#connDisconnectBtn').addEventListener('click', () => this.handleDisconnect());

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && $('#connModalOverlay').classList.contains('is-open')) this.closeModal();
      });

      this.updateUI(NUMD_SYNC.getStatus());
    },

    updateUI(status) {
      const btn = $('#connIndicator');
      const label = $('#connIndicatorLabel');
      btn.classList.remove('is-online', 'is-offline', 'is-checking');

      if (!status.configured) {
        btn.classList.add('is-offline');
        label.textContent = 'Offline';
      } else if (status.checking) {
        btn.classList.add('is-checking');
        label.textContent = 'Memeriksa...';
      } else if (status.online && status.authenticated) {
        btn.classList.add('is-online');
        label.textContent = status.queueLength > 0 ? ('Sinkron (' + status.queueLength + ')') : 'Online';
      } else {
        btn.classList.add('is-offline');
        label.textContent = 'Offline';
      }

      this.renderSyncBanner(status);
      this.renderModalState(status);
    },

    renderSyncBanner(status) {
      let banner = document.getElementById('syncPendingBanner');
      if (status.queueLength > 0) {
        if (!banner) {
          banner = document.createElement('div');
          banner.id = 'syncPendingBanner';
          banner.className = 'sync-pending-banner';
          document.body.appendChild(banner);
        }
        banner.innerHTML = '<i class="fa-solid fa-cloud-arrow-up"></i> ' + status.queueLength +
          ' perubahan menunggu disinkron' + (status.online ? '' : ' (offline)');
      } else if (banner) {
        banner.remove();
      }
    },

    renderModalState(status) {
      const connectedView = $('#connConnectedView');
      const form = $('#connForm');

      if (status.configured) {
        connectedView.hidden = false;
        form.hidden = true;

        const icon = $('#connStatusBanner').querySelector('i');
        if (status.online && status.authenticated) {
          icon.className = 'fa-solid fa-circle-check';
          $('#connStatusSub').textContent = 'Data tersinkron dengan Google Sheets.';
        } else if (status.online && !status.authenticated) {
          icon.className = 'fa-solid fa-triangle-exclamation';
          $('#connStatusSub').textContent = 'Sesi berakhir — sambungkan ulang untuk melanjutkan sinkronisasi.';
        } else {
          icon.className = 'fa-solid fa-plug-circle-xmark';
          $('#connStatusSub').textContent = 'Server tidak dapat dihubungi. Aplikasi tetap berjalan offline.';
        }

        const queueNote = $('#connQueueNote');
        queueNote.hidden = status.queueLength === 0;
        if (status.queueLength > 0) {
          queueNote.textContent = status.queueLength + ' perubahan lokal menunggu disinkron ke cloud.';
        }
      } else {
        connectedView.hidden = true;
        form.hidden = false;
      }
    },

    openModal() {
      const overlay = $('#connModalOverlay');
      overlay.hidden = false;
      requestAnimationFrame(() => overlay.classList.add('is-open'));
      document.body.style.overflow = 'hidden';
    },

    closeModal() {
      const overlay = $('#connModalOverlay');
      overlay.classList.remove('is-open');
      document.body.style.overflow = '';
      setTimeout(() => { overlay.hidden = true; }, 220);
    },

    clearFormErrors() {
      ['errConnUrl', 'errConnUsername', 'errConnPassword'].forEach(id => {
        const el = $('#' + id);
        if (el) el.textContent = '';
      });
    },

    async handleConnect(e) {
      e.preventDefault();
      this.clearFormErrors();

      const url = $('#connFormUrl').value.trim();
      const username = $('#connFormUsername').value.trim();
      const password = $('#connFormPassword').value;

      let valid = true;
      if (!url) { $('#errConnUrl').textContent = 'URL wajib diisi'; valid = false; }
      else if (!/^https:\/\/.+/.test(url)) { $('#errConnUrl').textContent = 'URL harus diawali https://'; valid = false; }
      if (!username) { $('#errConnUsername').textContent = 'Username wajib diisi'; valid = false; }
      if (!password) { $('#errConnPassword').textContent = 'Password wajib diisi'; valid = false; }
      if (!valid) return;

      const btn = $('#connModalSubmit');
      btn.disabled = true;
      $('#connModalSpinner').hidden = false;
      btn.querySelector('.btn-label').textContent = 'Menyambungkan...';

      try {
        await NUMD_SYNC.connect(url, username, password);
        Toast.show('Berhasil tersambung ke Google Sheets', 'success');
        this.closeModal();
        await performInitialSyncDown();
      } catch (err) {
        Toast.show(this.friendlyError(err), 'error');
      } finally {
        btn.disabled = false;
        $('#connModalSpinner').hidden = true;
        btn.querySelector('.btn-label').textContent = 'Sambungkan';
      }
    },

    async handleRetry() {
      const btn = $('#connRetryBtn');
      btn.disabled = true;
      const icon = btn.querySelector('i');
      icon.className = 'fa-solid fa-spinner fa-spin';

      const ok = await NUMD_SYNC.checkConnectivity();

      btn.disabled = false;
      icon.className = 'fa-solid fa-rotate';
      Toast.show(ok ? 'Koneksi normal, data tersinkron.' : 'Masih belum bisa terhubung ke server.', ok ? 'success' : 'error');

      if (ok) await performInitialSyncDown();
    },

    handleDisconnect() {
      NUMD_SYNC.disconnect();
      Toast.show('Koneksi ke cloud diputuskan. Aplikasi tetap berjalan offline sepenuhnya.', 'info');
      this.closeModal();
    },

    friendlyError(err) {
      switch (err.code) {
        case 'NETWORK_ERROR': return 'Tidak dapat menghubungi URL tersebut. Periksa URL & koneksi internet.';
        case 'TIMEOUT': return 'Server tidak merespons (timeout). Coba lagi.';
        case 'INVALID_JSON':
        case 'INVALID_SHAPE': return 'Respons server tidak dikenali. Pastikan URL Web App sudah benar.';
        case 'API_ERROR': return err.message; // pesan dari backend (mis. "Username atau password salah") sudah aman ditampilkan
        default: return err.message || 'Gagal menyambungkan ke server.';
      }
    },
  };

  /**
   * Dipanggil setelah local mutation (tambah/edit/hapus transaksi,
   * buat/ubah target) berhasil di state lokal. Kalau tersambung &
   * online, kirim ke backend langsung; kalau gagal karena masalah
   * jaringan, antre untuk disinkron nanti. Kalau memang belum
   * tersambung sama sekali, tidak melakukan apa pun (aplikasi murni
   * offline, tidak ada yang perlu diantre).
   */
  async function syncMutation(queueType, queuePayload, apiCallFn) {
    const status = NUMD_SYNC.getStatus();
    if (!status.configured) return { skipped: true };

    if (status.online && status.authenticated) {
      try {
        await apiCallFn();
        return { synced: true };
      } catch (err) {
        const retriable = err && (err.code === 'NETWORK_ERROR' || err.code === 'TIMEOUT' ||
          (err.code === 'HTTP_ERROR' && err.httpStatus >= 500));
        if (retriable) {
          NUMD_SYNC.enqueue(queueType, queuePayload);
          Toast.show('Koneksi terputus — perubahan disimpan & akan disinkron otomatis.', 'info');
        } else {
          Toast.show('Gagal menyimpan ke cloud: ' + err.message, 'error');
        }
        return { synced: false, error: err };
      }
    }

    NUMD_SYNC.enqueue(queueType, queuePayload);
    return { synced: false, queued: true };
  }

  /**
   * Tarik data terkini dari backend (transaksi + target aktif) dan
   * GANTI state lokal dengannya — dipanggil sekali setelah berhasil
   * connect/reconnect. Tidak dipanggil berulang supaya tidak boros
   * request; setelah ini state lokal jadi sumber kebenaran untuk
   * render, disinkron ke server per-mutasi lewat syncMutation().
   */
  async function performInitialSyncDown() {
    const status = NUMD_SYNC.getStatus();
    if (!status.online || !status.authenticated) return;

    try {
      const txResult = await NUMD_TX_API.getTransactions({ limit: 500 });
      state.transactions = (txResult.transactions || []).map(t => ({
        id: t.id,
        tanggal: t.tanggal,
        tipe: t.tipe,
        kategori: t.kategori,
        nominal: Number(t.nominal),
        keterangan: t.keterangan || '',
        target_id: t.target_id || '',
      }));

      let targetResult = null;
      try {
        targetResult = await NUMD_TARGET_API.getTarget();
      } catch (err) {
        targetResult = null; // wajar: memang belum ada target aktif di server
      }

      state.target = targetResult ? {
        id: targetResult.id,
        nama_target: targetResult.nama_target,
        target_nominal: Number(targetResult.target_nominal),
        tanggal_mulai: targetResult.tanggal_mulai,
        status: targetResult.status || 'ACTIVE',
      } : null;

      state.txPageLoaded = true;
      state.targetPageLoaded = true;
      state.remoteAchievements = null; // paksa AchievementPage ambil ulang saat dibuka berikutnya

      renderDashboard();
      TxPage.render();
      TargetPage.render();
      refreshStatistikIfLoaded();
      if (state.achPageLoaded) AchievementPage.ensureLoaded();

      Toast.show('Data berhasil disinkronkan dari Google Sheets', 'success');
    } catch (err) {
      Toast.show('Gagal mengambil data dari cloud: ' + err.message, 'error');
    }
  }

  /* ---------------------------------------------------------
     17. MISC: hero balance eye toggle
  --------------------------------------------------------- */

  function initHeroBalanceToggle() {
    $('#toggleBalanceVisibility').addEventListener('click', () => {
      balanceVisible = !balanceVisible;
      const icon = $('#toggleBalanceVisibility').querySelector('i');
      icon.className = balanceVisible ? 'fa-regular fa-eye' : 'fa-regular fa-eye-slash';
      renderHeroBalance();
    });
  }

  function initWelcomeBanner() {
    $('#welcomeAddTxBtn').addEventListener('click', () => TxModal.open('add'));
  }

  /* ---------------------------------------------------------
     18. INIT
  --------------------------------------------------------- */

  async function init() {
    restoreAchievementDataFromStorage();

    ThemeManager.init();
    renderGreeting();
    initHeroBalanceToggle();
    initWelcomeBanner();
    renderDashboard();
    renderLevelCard();
    renderSummaryBars();
    renderAchievementStrip();

    Router.init();
    TxPage.init();
    TxModal.init();
    ConfirmModal.init();
    TargetPage.init();
    TargetModal.init();
    StatistikPage.init();
    AchievementPage.init();
    ConnectionUI.init();

    // NUMD_SYNC.init() memuat konfigurasi koneksi tersimpan (kalau ada),
    // mengecek konektivitas, dan otomatis memutar ulang antrean offline.
    // Berjalan async supaya tidak menunda render pertama (yang sudah
    // memakai state kosong/fresh-app di atas).
    await NUMD_SYNC.init();
    const status = NUMD_SYNC.getStatus();
    if (status.online && status.authenticated) {
      await performInitialSyncDown();
    }
  }

  document.addEventListener('DOMContentLoaded', init);
})();
