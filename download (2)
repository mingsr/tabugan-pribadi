  /**
   * Hitung total saldo tabungan (SAVING - WITHDRAWAL) untuk target
   * tertentu dari daftar transaksi. Null-safe.
   */
  function computeTargetSaving(target, transactions) {
    if (!target) return 0;
    let total = 0;
    transactions.forEach(tx => {
      if (String(tx.target_id) === String(target.id)) {
        if (tx.tipe === TX_TYPE.SAVING) total += tx.nominal;
        if (tx.tipe === TX_TYPE.WITHDRAWAL) total -= tx.nominal;
      }
    });
    return Math.max(0, total);
  }

  function computeTargetProgress(target, transactions) {
    if (!target) return { saving: 0, remaining: 0, persen: 0 };
    const saving = computeTargetSaving(target, transactions);
    const persen = target.target_nominal > 0
      ? Math.min(100, Math.round((saving / target.target_nominal) * 10000) / 100)
      : 0;
    return {
      saving: saving,
      remaining: Math.max(0, target.target_nominal - saving),
      persen: persen,
    };
  }

  /**
   * Estimasi tanggal target tercapai berdasarkan rata-rata nabung
   * (tipe SAVING) 30 hari terakhir untuk target ini — meniru logika
   * predictTargetDate() di backend (04_Targets.gs) supaya hasil
   * konsisten begitu API asli disambungkan di Tahap 6.
   */
  function estimateTargetCompletion(target, transactions) {
    if (!target) return { type: 'none' };

    const progress = computeTargetProgress(target, transactions);
    if (progress.remaining <= 0) return { type: 'done' };

    const cutoff = new Date(TODAY);
    cutoff.setDate(cutoff.getDate() - 29);
    const cutoffStr = cutoff.toISOString().slice(0, 10);

    let saving30 = 0;
    transactions.forEach(tx => {
      if (String(tx.target_id) === String(target.id) &&
          tx.tipe === TX_TYPE.SAVING &&
          tx.tanggal >= cutoffStr && tx.tanggal <= TODAY) {
        saving30 += tx.nominal;
      }
    });

    const avgPerDay = saving30 / 30;
    if (avgPerDay <= 0) return { type: 'unknown' };

    const daysNeeded = Math.ceil(progress.remaining / avgPerDay);
    const estDate = new Date(TODAY);
    estDate.setDate(estDate.getDate() + daysNeeded);

    return { type: 'estimated', date: estDate.toISOString().slice(0, 10), days: daysNeeded };
  }

  /**
   * Total tabungan bersih sepanjang waktu, lintas SEMUA target
   * (bukan cuma target aktif) — dipakai untuk sistem Level, meniru
   * perhitungan totalSavingAll di backend (06_Dashboard.gs).
   */
  function computeTotalSavingAllTime(transactions) {
    let total = 0;
    transactions.forEach(tx => {
      if (tx.tipe === TX_TYPE.SAVING) total += tx.nominal;
      if (tx.tipe === TX_TYPE.WITHDRAWAL) total -= tx.nominal;
    });
    return Math.max(0, total);
  }

  /**
   * Hitung streak (jumlah hari berturut-turut menabung, dihitung
   * mundur dari TODAY) — meniru getStreakDays() di backend.
   */
  function computeStreakDays(transactions) {
    const savingDates = new Set();
    transactions.forEach(tx => {
      if (tx.tipe === TX_TYPE.SAVING) savingDates.add(tx.tanggal);
    });
    if (savingDates.size === 0) return 0;

    const today = new Date(TODAY);
    let streak = 0;
    for (let i = 0; i < 366; i++) {
      const d = new Date(today);
      d.setDate(today.getDate() - i);
      const str = d.toISOString().slice(0, 10);
      if (savingDates.has(str)) {
        streak++;
      } else if (i !== 0) {
        break;
      }
    }
    return streak;
  }

  /**
   * Bandingkan saldo bersih (income - expense) 30 hari terakhir
   * dengan 30 hari sebelumnya, untuk badge tren di kartu saldo.
   * Mengembalikan null jika belum ada basis pembanding (periode
   * sebelumnya nihil) supaya UI bisa menyembunyikan badge alih-alih
   * menampilkan persentase yang menyesatkan.
   */
  function computeBalanceTrend(transactions) {
    const today = new Date(TODAY);

    const curStart = new Date(today); curStart.setDate(today.getDate() - 29);
    const prevEnd = new Date(curStart); prevEnd.setDate(curStart.getDate() - 1);
    const prevStart = new Date(prevEnd); prevStart.setDate(prevEnd.getDate() - 29);

    const curStartStr = curStart.toISOString().slice(0, 10);
    const prevStartStr = prevStart.toISOString().slice(0, 10);
    const prevEndStr = prevEnd.toISOString().slice(0, 10);

    let curNet = 0, prevNet = 0;
    transactions.forEach(tx => {
      const amount = tx.tipe === TX_TYPE.INCOME ? tx.nominal : (tx.tipe === TX_TYPE.EXPENSE ? -tx.nominal : 0);
      if (tx.tanggal >= curStartStr && tx.tanggal <= TODAY) curNet += amount;
      if (tx.tanggal >= prevStartStr && tx.tanggal <= prevEndStr) prevNet += amount;
    });

    if (prevNet === 0) return null;

    const pct = ((curNet - prevNet) / Math.abs(prevNet)) * 100;
    return { pct: Math.round(pct * 10) / 10, up: pct >= 0 };
  }

  /**
   * Ringkasan harian untuk N hari terakhir — meniru getDailyChartData()
   * di backend. Dipakai oleh grafik "Ringkasan Bulan Ini" di dashboard.
   */
  function computeDailyChartData(days, transactions) {
    const today = new Date(TODAY);
    const result = [];

    for (let i = days - 1; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(today.getDate() - i);
      const str = d.toISOString().slice(0, 10);

      let income = 0, expense = 0, saving = 0;
      transactions.forEach(tx => {
        if (tx.tanggal !== str) return;
        if (tx.tipe === TX_TYPE.INCOME) income += tx.nominal;
        if (tx.tipe === TX_TYPE.EXPENSE) expense += tx.nominal;
        if (tx.tipe === TX_TYPE.SAVING) saving += tx.nominal;
      });

      result.push({ label: d.getDate() + ' ' + BULAN_PENDEK[d.getMonth()], income: income, expense: expense, saving: saving });
    }

    return result;
  }

  function getDerivedDashboardData() {
    const cutoff = new Date(TODAY);
    cutoff.setDate(cutoff.getDate() - 29);
    const cutoffStr = cutoff.toISOString().slice(0, 10);

    let totalIncome = 0, totalExpense = 0;

    state.transactions.forEach(tx => {
      if (tx.tanggal >= cutoffStr && tx.tanggal <= TODAY) {
        if (tx.tipe === TX_TYPE.INCOME) totalIncome += tx.nominal;
        if (tx.tipe === TX_TYPE.EXPENSE) totalExpense += tx.nominal;
      }
    });

    const progress = computeTargetProgress(state.target, state.transactions);

    return {
      totalIncome: totalIncome,
      totalExpense: totalExpense,
      targetSaving: progress.saving,
      targetRemaining: progress.remaining,
      persen: progress.persen,
    };
  }

