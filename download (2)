    render() {
      if (!state.statPageLoaded) return;

      if (state.transactions.length === 0) {
        $('#statContent').hidden = true;
        $('#statEmptyState').hidden = false;
        this.destroyCharts();
        return;
      }

      $('#statEmptyState').hidden = true;
      $('#statContent').hidden = false;

      const buckets = buildBuckets(state.statFilter);
      const agg = aggregateByBuckets(buckets, state.transactions);

      this.renderSummary(agg, buckets);
      this.renderCharts(buckets, agg);
      this.renderInsight();
    },

    renderSummary(agg, buckets) {
      const totalIncome = sumRange(agg.income);
      const totalExpense = sumRange(agg.expense);
      const totalSaving = sumRange(agg.saving);

      // Saldo saat ini = saldo kumulatif sepanjang waktu (all-time), bukan per-periode filter
      let currentBalance = 0;
      state.transactions.forEach(tx => {
        if (tx.tipe === TX_TYPE.INCOME) currentBalance += tx.nominal;
        if (tx.tipe === TX_TYPE.EXPENSE) currentBalance -= tx.nominal;
      });

      $('#statTotalIncome').textContent = formatRupiah(totalIncome);
      $('#statTotalExpense').textContent = formatRupiah(totalExpense);
      $('#statTotalSaving').textContent = formatRupiah(totalSaving);
      $('#statCurrentBalance').textContent = formatRupiah(currentBalance);
      $('#statTxCount').textContent = agg.txCount.toLocaleString('id-ID');

      const periodLabel = STAT_PERIOD_LABEL[state.statFilter] + ' · ' + buckets[0].label + '–' + buckets[buckets.length - 1].label;
      $('#statPeriodLabelIncome').textContent = periodLabel;
      $('#statPeriodLabelExpense').textContent = periodLabel;
      $('#statPeriodLabelSaving').textContent = periodLabel;
      $('#statPeriodLabelCount').textContent = periodLabel;

      $('#statTrendRangeLabel').textContent = buckets[0].label + ' – ' + buckets[buckets.length - 1].label;
      $('#statBalanceRangeLabel').textContent = buckets[0].label + ' – ' + buckets[buckets.length - 1].label;
    },

    destroyCharts() {
      Object.keys(state.charts).forEach(key => {
        if (state.charts[key]) {
          state.charts[key].destroy();
          state.charts[key] = null;
        }
      });
    },

    renderCharts(buckets, agg) {
      if (typeof Chart === 'undefined') return; // CDN gagal dimuat (mis. offline) — gagal secara aman

      const labels = buckets.map(b => b.label);
      const colorMint = getCSSVar('--accent-mint');
      const colorCoral = getCSSVar('--accent-coral');
      const colorGold = getCSSVar('--accent-gold');
      const colorViolet = getCSSVar('--accent-violet');
      const colorText = getCSSVar('--text-secondary');
      const colorGrid = getCSSVar('--border-glass');
      const fontFamily = getCSSVar('--font-body') || 'sans-serif';

      Chart.defaults.font.family = fontFamily;
      Chart.defaults.color = colorText;

      const commonScales = {
