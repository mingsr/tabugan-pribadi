  const STAT_PERIOD_LABEL = {
    day: 'Harian',
    week: 'Mingguan',
    month: 'Bulanan',
    year: 'Tahunan',
  };

  function getCSSVar(name) {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }

  function pad2(n) { return String(n).padStart(2, '0'); }

  function toISODate(d) {
    return d.getFullYear() + '-' + pad2(d.getMonth() + 1) + '-' + pad2(d.getDate());
  }

  function startOfWeek(d) {
    // Senin sebagai awal minggu
    const day = d.getDay(); // 0=Minggu
    const diff = (day === 0 ? -6 : 1 - day);
    const monday = new Date(d);
    monday.setDate(d.getDate() + diff);
    return monday;
  }

  /**
   * Membuat daftar bucket (rentang tanggal) sesuai tipe periode,
   * berakhir pada TODAY. Dipakai untuk mengelompokkan transaksi
   * pada grafik tren & saldo.
   */
  function buildBuckets(periodType) {
    const today = new Date(TODAY);
    const buckets = [];

    if (periodType === 'day') {
      for (let i = 13; i >= 0; i--) {
        const d = new Date(today);
        d.setDate(today.getDate() - i);
        const iso = toISODate(d);
        buckets.push({ key: iso, label: d.getDate() + ' ' + BULAN_PENDEK[d.getMonth()], start: iso, end: iso });
      }
    } else if (periodType === 'week') {
      const thisMonday = startOfWeek(today);
      for (let i = 7; i >= 0; i--) {
        const start = new Date(thisMonday);
        start.setDate(thisMonday.getDate() - (i * 7));
        const end = new Date(start);
        end.setDate(start.getDate() + 6);
        buckets.push({
          key: toISODate(start),
          label: start.getDate() + ' ' + BULAN_PENDEK[start.getMonth()],
          start: toISODate(start),
          end: toISODate(end),
        });
      }
    } else if (periodType === 'year') {
      const thisYear = today.getFullYear();
      for (let i = 2; i >= 0; i--) {
        const y = thisYear - i;
        buckets.push({ key: String(y), label: String(y), start: y + '-01-01', end: y + '-12-31' });
      }
    } else { // 'month' (default)
      for (let i = 5; i >= 0; i--) {
        const d = new Date(today.getFullYear(), today.getMonth() - i, 1);
        const y = d.getFullYear();
        const m = d.getMonth();
        const lastDay = new Date(y, m + 1, 0).getDate();
        buckets.push({
          key: y + '-' + pad2(m + 1),
          label: BULAN_PENDEK[m] + ' ' + y,
          start: y + '-' + pad2(m + 1) + '-01',
          end: y + '-' + pad2(m + 1) + '-' + pad2(lastDay),
        });
      }
    }

    return buckets;
  }

  /**
   * Kelompokkan transaksi ke dalam bucket, hasilkan total per tipe
   * per bucket plus saldo kumulatif (untuk grafik perkembangan saldo).
   */
  function aggregateByBuckets(buckets, transactions) {
    const income = new Array(buckets.length).fill(0);
    const expense = new Array(buckets.length).fill(0);
    const saving = new Array(buckets.length).fill(0);
    let txCount = 0;

    transactions.forEach(tx => {
      const idx = buckets.findIndex(b => tx.tanggal >= b.start && tx.tanggal <= b.end);
      if (idx === -1) return;
      txCount++;
      if (tx.tipe === TX_TYPE.INCOME) income[idx] += tx.nominal;
      if (tx.tipe === TX_TYPE.EXPENSE) expense[idx] += tx.nominal;
      if (tx.tipe === TX_TYPE.SAVING) saving[idx] += tx.nominal;
    });

    // Saldo kumulatif sepanjang seluruh riwayat transaksi sampai akhir tiap bucket
    // (bukan cuma dalam rentang bucket yang tampil), supaya grafik saldo akurat
    // mencerminkan saldo riil pada titik waktu tersebut.
    const balance = buckets.map(b => {
      let bal = 0;
      transactions.forEach(tx => {
        if (tx.tanggal > b.end) return;
        if (tx.tipe === TX_TYPE.INCOME) bal += tx.nominal;
        if (tx.tipe === TX_TYPE.EXPENSE) bal -= tx.nominal;
      });
      return bal;
    });

    return { income, expense, saving, balance, txCount };
  }

  function sumRange(arr) { return arr.reduce((a, b) => a + b, 0); }

  /**
   * Insight sederhana lintas seluruh riwayat transaksi (tidak
   * tergantung filter periode aktif), dikelompokkan per bulan.
   */
  function computeInsights(transactions) {
    const monthMap = {}; // 'YYYY-MM' -> { income, expense, label }

    transactions.forEach(tx => {
      const ym = tx.tanggal.slice(0, 7);
      if (!monthMap[ym]) {
        const d = new Date(ym + '-01');
        monthMap[ym] = { income: 0, expense: 0, saving: 0, label: BULAN_PENDEK[d.getMonth()] + ' ' + d.getFullYear() };
      }
      if (tx.tipe === TX_TYPE.INCOME) monthMap[ym].income += tx.nominal;
      if (tx.tipe === TX_TYPE.EXPENSE) monthMap[ym].expense += tx.nominal;
      if (tx.tipe === TX_TYPE.SAVING) monthMap[ym].saving += tx.nominal;
    });

    const months = Object.values(monthMap);
    let totalIncomeAll = 0, totalSavingAll = 0;
    months.forEach(m => { totalIncomeAll += m.income; totalSavingAll += m.saving; });

    let topIncomeMonth = null, topExpenseMonth = null;
    months.forEach(m => {
      if (m.income > 0 && (!topIncomeMonth || m.income > topIncomeMonth.income)) topIncomeMonth = m;
      if (m.expense > 0 && (!topExpenseMonth || m.expense > topExpenseMonth.expense)) topExpenseMonth = m;
    });

    const savingPercent = totalIncomeAll > 0 ? Math.round((totalSavingAll / totalIncomeAll) * 1000) / 10 : 0;

    return { topIncomeMonth, topExpenseMonth, savingPercent, hasData: months.length > 0 };
  }

  const StatistikPage = {
    async ensureLoaded() {
      if (state.statPageLoaded) {
        this.render();
        return;
      }
      await this.simulateFetch();
      state.statPageLoaded = true;
