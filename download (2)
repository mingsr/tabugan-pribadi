   * Catatan: ini TERPISAH dari skor "Total XP" (yang berasal dari
   * achievement) — keduanya sengaja tidak dicampur.
   */
  const LEVELS = [
    { level: 1,  nama: 'Telur Menetas',     threshold: 0,         icon: '🥚' },
    { level: 2,  nama: 'Bibit Harapan',     threshold: 50000,     icon: '🌱' },
    { level: 3,  nama: 'Pemula Bijak',      threshold: 200000,    icon: '🔰' },
    { level: 4,  nama: 'Calon Hemat',       threshold: 500000,    icon: '💡' },
    { level: 5,  nama: 'Penabung Aktif',    threshold: 1000000,   icon: '⚡' },
    { level: 6,  nama: 'Penjaga Rupiah',    threshold: 2500000,   icon: '🔷' },
    { level: 7,  nama: 'Warrior Tabungan',  threshold: 5000000,   icon: '🌟' },
    { level: 8,  nama: 'Diamond Saver',     threshold: 10000000,  icon: '💎' },
    { level: 9,  nama: 'Sultan Masa Depan', threshold: 15000000,  icon: '👑' },
    { level: 10, nama: 'Laptop Acquired',   threshold: 20000000,  icon: '🚀' },
  ];

  function calculateLevel(totalSaving) {
    let current = LEVELS[0];
    for (let i = LEVELS.length - 1; i >= 0; i--) {
      if (totalSaving >= LEVELS[i].threshold) { current = LEVELS[i]; break; }
    }
    const next = LEVELS.find(l => l.level === current.level + 1) || null;

    let progressPersen = 100;
    if (next) {
      const range = next.threshold - current.threshold;
      const progress = totalSaving - current.threshold;
      progressPersen = range > 0 ? Math.min(100, (progress / range) * 100) : 100;
    }

    return {
      level: current.level,
      nama: current.nama,
      icon: current.icon,
      threshold_current: current.threshold,
      threshold_next: next ? next.threshold : null,
      next_nama: next ? next.nama : null,
      progress_persen: Math.round(progressPersen * 100) / 100,
    };
  }

